{
  "multipart": [
    {
      "when": {
        "up": "true"
      },
      "apply": {
        "model": "verseworks:block/warp_vine"
      }
    },
    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "verseworks:block/warp_vine"
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "verseworks:block/warp_vine",
        "y": 90
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "verseworks:block/warp_vine",
        "y": 180
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "verseworks:block/warp_vine",
        "y": 270
      }
    },
    {
      "when": {
        "down": "true"
      },
      "apply": {
        "model": "verseworks:block/warp_vine_ground"
      }
    }
  ]
}